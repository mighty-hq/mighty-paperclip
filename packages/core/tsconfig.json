{

  "compilerOptions": {

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "sourceMap": true,

    "isolatedModules": true,
    "lib": ["es2022", "DOM", "DOM.Iterable", "esnext", "webworker"],
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "strictNullChecks": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "jsx": "react-jsx",
    "noImplicitAny": false,

    "noEmit": true,
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],

 
 
    "types": [
      "react",
      "react-dom",
      "node"

    ],
   
  },
  "include": [    
    "./global.d.ts",

    "src/**/*.ts",
    "src/**/*.tsx",
    "*.mts",
    "assets/*",
    ".next/types/**/*.ts",
  "next-env.d.ts",
  ".next/dev/types/**/*.ts",
       "next-env.d.ts",

      ],

  "exclude": [
    "node_modules"
  ]
}